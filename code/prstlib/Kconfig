module = PRSTLIB
module-str = prstlib
source "subsys/logging/Kconfig.template.log_config"

config PRSTLIB_BATT_VOLTAGE_DIVIDER
	int "Battery ADC voltage divider ratio"
	default 1
	help
	  Multiplier applied to the battery ADC reading to recover the true
	  battery voltage. Set to 5 when the battery channel samples
	  NRF_SAADC_VDDHDIV5 (i.e. when the board runs in high-voltage mode
	  with VDD regulated below VDDH). Leave at 1 when the channel samples
	  NRF_SAADC_VDD directly.

menu "Soil moisture calibration (regulated VDD only)"

config PRSTLIB_SOIL_DRY_RAW
	int "Raw ADC reading at dry endpoint (sensor in air)"
	default 510
	help
	  Raw 10-bit SAADC reading expected with the sensor in air. Measured
	  on-bench at the regulated VDD: flash a --dev build, observe the
	  raw value in the LOG_DBG output with the sensor untouched. Only
	  consulted when REGOUT0 regulates VDD; on default-REGOUT0 builds
	  the legacy polynomial fit from soil_calibration_coeffs (DT) is
	  used instead.

config PRSTLIB_SOIL_WET_RAW
	int "Raw ADC reading at wet endpoint (sensor in water)"
	default 179
	help
	  Raw 10-bit SAADC reading expected with the sensor submerged in
	  tap water. See PRSTLIB_SOIL_DRY_RAW for measurement procedure.

endmenu

config PRSTLIB_DEV_FAST_LOOP
	bool "Use the bring-up wake cadence instead of the production default"
	default n
	help
	  Single shared knob that the dev snippet flips on. Each sample's
	  Kconfig consults this to pick a shorter sleep duration (e.g. 5 s
	  for ble, 10 s for zigbee) so bench iteration is fast without
	  needing per-sample overrides on the command line. Leave off for
	  battery deployment.

menu "Phototransistor calibration"

config PRSTLIB_PHOTO_LUX_SUN
	int "Reference lux value for current_sun calibration point"
	default 10000
	help
	  Illuminance (in lux) at which PRSTLIB_PHOTO_CURRENT_SUN_UA of
	  photocurrent is expected. Calibration is linear from there:
	  brightness_lux = (V_adc / R_output) * lux_sun / current_sun.

config PRSTLIB_PHOTO_CURRENT_SUN_UA
	int "Photocurrent at PRSTLIB_PHOTO_LUX_SUN, in microamps"
	default 3546
	help
	  With the 470 Ω output resistor, 3546 µA at 10000 lux yields the
	  measured response of 6 lux per mV of ADC voltage (e.g. 400 mV ->
	  2400 lux). Recalibrate when VDD or the output resistor changes —
	  the photocurrent at the same illuminance scales with the drive
	  voltage.

endmenu
