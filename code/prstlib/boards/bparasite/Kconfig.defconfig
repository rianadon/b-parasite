
if BOARD_BPARASITE

config BOARD
	default "bparasite"

config BOARD_REVISION
	string "Board revision."
	default "1.0.0"

config BOARD_REVISION_CODE
	int "Board revision code. An integer representation of the board revision."
	default 1

# When REGOUT0 is non-default the board.c hook programs UICR.REGOUT0 to
# regulate VDD below VDDH, which means the battery channel must sample
# VDDH/5 (see bparasite_nrf52840_2_0_0_ry1.overlay) and the firmware
# must scale the reading back up by 5.
config PRSTLIB_BATT_VOLTAGE_DIVIDER
	default 5 if !BPARASITE_REGOUT0_DEFAULT && BOARD_BPARASITE_NRF52840

# Cap BLE TX power to what the regulated VDD can actually sustain.
# +8 dBm requires VDD ≳ 2.7 V under TX peaks; +4 dBm needs ≳ 2.4 V; below
# that the controller falls back to 0 dBm. Sample-level prj.conf can
# still override these.
if BT && BOARD_BPARASITE_NRF52840

choice BT_CTLR_TX_PWR
	default BT_CTLR_TX_PWR_0      if BPARASITE_REGOUT0_DEFAULT
	default BT_CTLR_TX_PWR_0      if BPARASITE_REGOUT0_2V1
	default BT_CTLR_TX_PWR_PLUS_4 if BPARASITE_REGOUT0_2V4
	default BT_CTLR_TX_PWR_PLUS_4 if BPARASITE_REGOUT0_2V7
	default BT_CTLR_TX_PWR_PLUS_8 if BPARASITE_REGOUT0_3V0
	default BT_CTLR_TX_PWR_PLUS_8 if BPARASITE_REGOUT0_3V3
endchoice

endif # BT && BOARD_BPARASITE_NRF52840

endif  # BOARD_BPARASITE
