/*
 * Route Zephyr's console to a USB CDC ACM virtual UART so the host can read
 * logs over the same USB connection used for flashing. zephyr_udc0 is the
 * nRF52840's native USB device controller (defined in Nordic's SoC dtsi).
 */
&usbd {
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};
};
